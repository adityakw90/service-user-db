# Liquibase Environment Variables
# Copy this file to .env and update with your actual database credentials
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#   make update

# PostgreSQL JDBC connection URL
# Format: jdbc:postgresql://host:port/database_name
DATABASE_URL=jdbc:postgresql://localhost:5432/service_user

# Database username
DATABASE_USER=your_username

# Database password
DATABASE_PASSWORD=your_password
